# EditorConfig - https://editorconfig.org
# XRNotify Repository Configuration

root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
max_line_length = 100

# TypeScript / JavaScript
[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2
quote_type = single

# JSON files
[*.json]
indent_size = 2
insert_final_newline = true

# YAML files
[*.{yml,yaml}]
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# SQL files
[*.sql]
indent_size = 2

# Shell scripts
[*.sh]
indent_size = 2
shell_variant = bash

# Dockerfile
[Dockerfile*]
indent_size = 2

# Makefile (requires tabs)
[Makefile]
indent_style = tab
indent_size = 4

# Environment files
[.env*]
insert_final_newline = true

# Package manager lock files
[{pnpm-lock.yaml,package-lock.json,yarn.lock}]
indent_size = 2
insert_final_newline = true

# Git configuration
[.git*]
indent_size = 2

# GitHub Actions
[.github/**/*.yml]
indent_size = 2

# Prose / Documentation
[*.{txt,rst}]
max_line_length = 80
