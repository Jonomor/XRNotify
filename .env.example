# ============================================
# XRNotify Environment Configuration
# ============================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================

# --------------------------------------------
# General
# --------------------------------------------
NODE_ENV=development
# Options: development, production, test

LOG_LEVEL=info
# Options: trace, debug, info, warn, error, fatal

LOG_FORMAT=json
# Options: json, pretty

# --------------------------------------------
# API Server
# --------------------------------------------
API_HOST=0.0.0.0
API_PORT=3000
API_BASE_URL=http://localhost:3000
# Production: https://api.xrnotify.io

# Request body size limit
API_BODY_LIMIT=1048576
# 1MB in bytes

# CORS origins (comma-separated)
API_CORS_ORIGINS=http://localhost:3001,http://localhost:3002
# Production: https://dashboard.xrnotify.io,https://xrnotify.io

# --------------------------------------------
# PostgreSQL Database
# --------------------------------------------
DATABASE_URL=postgresql://xrnotify:xrnotify_dev_password@localhost:5432/xrnotify
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Connection pool settings
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECTION_TIMEOUT_MS=10000

# SSL mode for production
DATABASE_SSL=false
# Production: true

# --------------------------------------------
# Redis
# --------------------------------------------
REDIS_URL=redis://localhost:6379
# Format: redis://[:PASSWORD@]HOST:PORT[/DATABASE]
# Production with TLS: rediss://...

# Redis key prefix for namespacing
REDIS_KEY_PREFIX=xrnotify:

# Connection settings
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY_MS=1000

# --------------------------------------------
# XRPL Connection
# --------------------------------------------
XRPL_WS_URL=wss://s1.ripple.com
# Options:
#   Mainnet: wss://s1.ripple.com, wss://s2.ripple.com, wss://xrplcluster.com
#   Testnet: wss://s.altnet.rippletest.net
#   Devnet: wss://s.devnet.rippletest.net

XRPL_WS_URL_FALLBACK=wss://s2.ripple.com
# Fallback server for high availability

XRPL_NETWORK=mainnet
# Options: mainnet, testnet, devnet

# Reconnection settings
XRPL_RECONNECT_DELAY_MS=5000
XRPL_RECONNECT_MAX_ATTEMPTS=10
XRPL_CONNECTION_TIMEOUT_MS=15000

# Ledger processing
XRPL_START_LEDGER_INDEX=latest
# Options: latest, validated, or specific ledger index number

# --------------------------------------------
# Authentication & Security
# --------------------------------------------
# API Key hashing (do not change after deployment)
API_KEY_HASH_ALGORITHM=sha256

# JWT Configuration (for dashboard sessions)
JWT_SECRET=CHANGE_ME_generate_64_char_random_string_here_use_openssl_rand_hex_32
JWT_ISSUER=xrnotify
JWT_AUDIENCE=xrnotify-dashboard
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# Session cookie settings
SESSION_COOKIE_NAME=xrnotify_session
SESSION_COOKIE_SECURE=false
# Production: true
SESSION_COOKIE_DOMAIN=localhost
# Production: .xrnotify.io

# Webhook signature settings
WEBHOOK_SIGNATURE_ALGORITHM=sha256
WEBHOOK_SIGNATURE_HEADER=X-XRNotify-Signature
WEBHOOK_TIMESTAMP_HEADER=X-XRNotify-Timestamp
WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300

# --------------------------------------------
# Rate Limiting
# --------------------------------------------
RATE_LIMIT_ENABLED=true

# Global rate limit (requests per window)
RATE_LIMIT_GLOBAL_MAX=1000
RATE_LIMIT_GLOBAL_WINDOW_MS=60000

# Per API key rate limit
RATE_LIMIT_API_KEY_MAX=100
RATE_LIMIT_API_KEY_WINDOW_MS=60000

# Webhook registration rate limit
RATE_LIMIT_WEBHOOK_CREATE_MAX=10
RATE_LIMIT_WEBHOOK_CREATE_WINDOW_MS=3600000

# --------------------------------------------
# Webhook Delivery
# --------------------------------------------
# HTTP client settings
WEBHOOK_DELIVERY_TIMEOUT_MS=10000
WEBHOOK_DELIVERY_MAX_REDIRECTS=3

# Retry policy
WEBHOOK_RETRY_MAX_ATTEMPTS=5
WEBHOOK_RETRY_INITIAL_DELAY_MS=1000
WEBHOOK_RETRY_MAX_DELAY_MS=300000
WEBHOOK_RETRY_BACKOFF_MULTIPLIER=2

# Dead letter queue
WEBHOOK_DLQ_ENABLED=true
WEBHOOK_DLQ_RETENTION_HOURS=168
# 7 days

# SSRF Protection
WEBHOOK_BLOCK_PRIVATE_IPS=true
WEBHOOK_REQUIRE_HTTPS=false
# Production: true
WEBHOOK_DNS_RESOLUTION_TIMEOUT_MS=5000

# --------------------------------------------
# Queue / Redis Streams
# --------------------------------------------
STREAM_EVENTS_NAME=xrnotify:events
STREAM_EVENTS_MAXLEN=100000

STREAM_DELIVERIES_NAME=xrnotify:deliveries
STREAM_DELIVERIES_MAXLEN=500000

STREAM_DLQ_NAME=xrnotify:dlq
STREAM_DLQ_MAXLEN=50000

STREAM_REPLAY_NAME=xrnotify:replay
STREAM_REPLAY_MAXLEN=100000

# Consumer group settings
CONSUMER_GROUP_NAME=xrnotify-workers
CONSUMER_BLOCK_MS=5000
CONSUMER_BATCH_SIZE=10
CONSUMER_CLAIM_IDLE_MS=60000

# --------------------------------------------
# Worker Service
# --------------------------------------------
WORKER_CONCURRENCY=5
WORKER_GRACEFUL_SHUTDOWN_MS=30000

# --------------------------------------------
# Listener Service
# --------------------------------------------
LISTENER_HEALTH_CHECK_INTERVAL_MS=30000
LISTENER_PERSIST_CURSOR_INTERVAL_MS=5000

# --------------------------------------------
# WebSocket Streaming (Optional)
# --------------------------------------------
WS_ENABLED=false
WS_PORT=3003
WS_PATH=/stream
WS_HEARTBEAT_INTERVAL_MS=30000
WS_MAX_CONNECTIONS_PER_KEY=5

# --------------------------------------------
# Metrics & Monitoring
# --------------------------------------------
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics

# Prometheus push gateway (optional)
METRICS_PUSH_GATEWAY_URL=
METRICS_PUSH_INTERVAL_MS=15000

# --------------------------------------------
# Data Retention
# --------------------------------------------
RETENTION_DELIVERIES_DAYS=30
RETENTION_EVENTS_DAYS=7
RETENTION_AUDIT_LOGS_DAYS=90

# Cleanup job schedule (cron format)
RETENTION_CLEANUP_CRON=0 3 * * *
# 3 AM daily

# --------------------------------------------
# Billing (Optional - Stripe)
# --------------------------------------------
BILLING_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Plan limits (events per month)
PLAN_FREE_EVENT_LIMIT=10000
PLAN_STARTER_EVENT_LIMIT=100000
PLAN_PRO_EVENT_LIMIT=1000000
PLAN_ENTERPRISE_EVENT_LIMIT=0
# 0 = unlimited

# --------------------------------------------
# Email Notifications (Optional)
# --------------------------------------------
EMAIL_ENABLED=false
EMAIL_PROVIDER=smtp
# Options: smtp, sendgrid, mailgun, ses

# SMTP settings
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=notifications@xrnotify.io
SMTP_FROM_NAME=XRNotify

# SendGrid
SENDGRID_API_KEY=

# --------------------------------------------
# Dashboard (Next.js)
# --------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3000
# Production: https://api.xrnotify.io

NEXT_PUBLIC_WS_URL=ws://localhost:3003
# Production: wss://stream.xrnotify.io

NEXT_PUBLIC_APP_NAME=XRNotify
NEXT_PUBLIC_APP_URL=http://localhost:3001
# Production: https://dashboard.xrnotify.io

# --------------------------------------------
# Documentation Site
# --------------------------------------------
DOCS_URL=http://localhost:3002
# Production: https://xrnotify.dev

# --------------------------------------------
# External Services (Production)
# --------------------------------------------
# Sentry error tracking
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Fly.io deployment
FLY_APP_NAME=xrnotify-api
FLY_REGION=iad

# --------------------------------------------
# Development & Testing
# --------------------------------------------
# Test webhook receiver
TEST_WEBHOOK_URL=https://webhook.site/your-unique-id

# Enable detailed error responses
DEBUG_ERRORS=true
# Production: false

# Seed data on startup
SEED_ON_STARTUP=false
