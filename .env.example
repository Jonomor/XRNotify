# =============================================================================
# XRNotify Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
# Options: development, test, production

PORT=3000
# API server port

API_BASE_URL=http://localhost:3000
# Public URL for the API (used in webhooks, callbacks)

DASHBOARD_URL=http://localhost:3001
# Dashboard URL for CORS and redirects

LOG_LEVEL=debug
# Options: trace, debug, info, warn, error, fatal

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://xrnotify:xrnotify_dev@localhost:5432/xrnotify
# Full connection string

# Or individual components (DATABASE_URL takes precedence):
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=xrnotify
# DB_USER=xrnotify
# DB_PASSWORD=xrnotify_dev

DB_POOL_MIN=2
# Minimum pool connections

DB_POOL_MAX=10
# Maximum pool connections

DB_SSL=false
# Enable SSL for database connection (true in production)

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
# Full Redis connection string

# Or individual components:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

REDIS_KEY_PREFIX=xrnotify:
# Prefix for all Redis keys

# -----------------------------------------------------------------------------
# XRPL Configuration
# -----------------------------------------------------------------------------
XRPL_NETWORK=mainnet
# Options: mainnet, testnet, devnet

XRPL_WS_URL=wss://xrplcluster.com
# Primary WebSocket endpoint

XRPL_WS_URL_FALLBACK=wss://s1.ripple.com
# Fallback WebSocket endpoint

XRPL_CONNECTION_TIMEOUT_MS=10000
# Connection timeout in milliseconds

XRPL_RECONNECT_DELAY_MS=1000
# Initial reconnect delay (uses exponential backoff)

XRPL_RECONNECT_MAX_ATTEMPTS=10
# Maximum reconnection attempts before giving up

XRPL_START_LEDGER_INDEX=validated
# Starting ledger: 'validated', 'current', or specific ledger index

# -----------------------------------------------------------------------------
# API Security
# -----------------------------------------------------------------------------
API_KEY_HASH_ALGORITHM=sha256
# Algorithm for hashing API keys

WEBHOOK_SIGNATURE_ALGORITHM=sha256
# Algorithm for signing webhook payloads

RATE_LIMIT_ENABLED=true
# Enable rate limiting

RATE_LIMIT_REQUESTS_PER_MINUTE=60
# Default rate limit per API key

RATE_LIMIT_BURST=10
# Burst allowance above rate limit

# -----------------------------------------------------------------------------
# Webhook Delivery
# -----------------------------------------------------------------------------
WEBHOOK_TIMEOUT_MS=30000
# Timeout for webhook HTTP requests

WEBHOOK_MAX_RETRIES=10
# Maximum retry attempts for failed deliveries

WEBHOOK_RETRY_DELAY_MS=1000
# Initial retry delay (uses exponential backoff)

WEBHOOK_ALLOW_LOCALHOST=false
# Allow localhost URLs (development only!)

WEBHOOK_ALLOW_PRIVATE_IPS=false
# Allow private IP ranges (NEVER in production)

# -----------------------------------------------------------------------------
# Worker Configuration
# -----------------------------------------------------------------------------
WORKER_CONCURRENCY=10
# Number of concurrent webhook deliveries

WORKER_BATCH_SIZE=100
# Number of events to process per batch

WORKER_POLL_INTERVAL_MS=100
# Polling interval for queue

# -----------------------------------------------------------------------------
# Session / Auth
# -----------------------------------------------------------------------------
SESSION_SECRET=change-me-to-a-random-64-char-string-in-production-use-openssl
# Secret for signing session cookies (min 32 chars)

SESSION_COOKIE_NAME=xrnotify_session
# Name of the session cookie

SESSION_MAX_AGE_MS=604800000
# Session duration: 7 days in milliseconds

# -----------------------------------------------------------------------------
# Stripe (Billing)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxxx
# Stripe secret key

STRIPE_PUBLISHABLE_KEY=pk_test_xxxx
# Stripe publishable key (for frontend)

STRIPE_WEBHOOK_SECRET=whsec_xxxx
# Stripe webhook endpoint secret

STRIPE_PRICE_ID_STARTER=price_xxxx
# Price ID for Starter plan

STRIPE_PRICE_ID_PRO=price_xxxx
# Price ID for Pro plan

# -----------------------------------------------------------------------------
# Email (Optional)
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@xrnotify.io

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
METRICS_ENABLED=true
# Enable Prometheus metrics endpoint

METRICS_PORT=9090
# Port for metrics server (if separate from API)

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
FEATURE_WEBSOCKET_STREAMING=false
# Enable WebSocket streaming (beta)

FEATURE_RAW_EVENTS=false
# Include raw XRPL transaction data in events

FEATURE_BILLING=false
# Enable Stripe billing integration

# -----------------------------------------------------------------------------
# Development Only
# -----------------------------------------------------------------------------
# DEBUG=xrnotify:*
# Enable debug logging for specific modules

# PRETTY_LOGS=true
# Enable pretty-printed logs (disable in production)

# -----------------------------------------------------------------------------
# H.U.N.I.E. Memory Engine
# -----------------------------------------------------------------------------
HUNIE_API_URL=http://hunie.railway.internal:3000
HUNIE_API_KEY=
HUNIE_AGENT_WALLET_MONITOR=
HUNIE_AGENT_NETWORK=
HUNIE_AGENT_USAGE=
