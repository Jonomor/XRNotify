{
  "name": "@xrnotify/backend",
  "version": "1.0.0",
  "description": "XRNotify Backend - API, Listener, and Worker Services",
  "author": "XRNotify <engineering@xrnotify.io>",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./entrypoint": {
      "types": "./dist/entrypoint.d.ts",
      "import": "./dist/entrypoint.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "build:watch": "tsc --build --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "dev": "tsx watch src/entrypoint.ts",
    "dev:api": "SERVICE_NAME=api tsx watch src/entrypoint.ts",
    "dev:listener": "SERVICE_NAME=listener tsx watch src/entrypoint.ts",
    "dev:worker": "SERVICE_NAME=worker tsx watch src/entrypoint.ts",
    "start": "node dist/entrypoint.js",
    "start:api": "SERVICE_NAME=api node dist/entrypoint.js",
    "start:listener": "SERVICE_NAME=listener node dist/entrypoint.js",
    "start:worker": "SERVICE_NAME=worker node dist/entrypoint.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:create": "tsx src/db/migrate.ts create"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/sensible": "^5.6.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@xrnotify/shared": "workspace:*",
    "fastify": "^4.26.2",
    "ioredis": "^5.3.2",
    "pg": "^8.11.5",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "prom-client": "^15.1.0",
    "xrpl": "^3.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/pg": "^8.11.4",
    "@typescript-eslint/eslint-plugin": "^7.4.0",
    "@typescript-eslint/parser": "^7.4.0",
    "@vitest/coverage-v8": "^2.1.1",
    "eslint": "^8.57.0",
    "tsx": "^4.7.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
