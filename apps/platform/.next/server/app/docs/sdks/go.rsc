3:T4cb,package main

import (
    "encoding/json"
    "io"
    "log"
    "net/http"
    "os"

    "github.com/xrnotify/xrnotify-go"
    "github.com/xrnotify/xrnotify-go/verify"
)

func webhookHandler(w http.ResponseWriter, r *http.Request) {
    body, err := io.ReadAll(r.Body)
    if err != nil {
        http.Error(w, "Bad request", http.StatusBadRequest)
        return
    }

    ok := verify.Signature(
        body,
        r.Header.Get("X-XRNotify-Signature"),
        os.Getenv("WEBHOOK_SECRET"),
    )
    if !ok {
        http.Error(w, "Unauthorized", http.StatusUnauthorized)
        return
    }

    var event xrnotify.Event
    if err := json.Unmarshal(body, &event); err != nil {
        http.Error(w, "Bad request", http.StatusBadRequest)
        return
    }

    log.Printf("Received event: %s in ledger %d", event.EventType, event.LedgerIndex)

    switch event.EventType {
    case "payment.xrp":
        // unmarshal event.Payload into xrnotify.PaymentXrpPayload
    case "nft.minted":
        // unmarshal event.Payload into xrnotify.NftMintedPayload
    }

    w.WriteHeader(http.StatusOK)
}

func main() {
    http.HandleFunc("/webhooks/xrpl", webhookHandler)
    log.Fatal(http.ListenAndServe(":8080", nil))
}6:T4b8,{"@context":"https://schema.org","@type":"SoftwareApplication","@id":"https://www.xrnotify.io/#app","name":"XRNotify","description":"Real-time webhook notification platform for the XRP Ledger.","url":"https://www.xrnotify.io","applicationCategory":"DeveloperApplication","operatingSystem":"Web","offers":[{"@type":"Offer","name":"Free","price":"0","priceCurrency":"USD","description":"1,000 events/month, 2 webhooks"},{"@type":"Offer","name":"Starter","price":"29.00","priceCurrency":"USD","description":"50,000 events/month, 10 webhooks, WebSocket access"},{"@type":"Offer","name":"Pro","price":"99.00","priceCurrency":"USD","description":"500,000 events/month, 50 webhooks, priority delivery"}],"creator":{"@id":"https://www.jonomor.com/ali-morgan#person"},"publisher":{"@id":"https://www.jonomor.com/#organization"},"isPartOf":{"@id":"https://www.jonomor.com/#organization"},"featureList":["Real-time XRPL event ingestion","HMAC-SHA256 signed webhook delivery","Automatic retries with exponential backoff","Dead-letter queue for failed deliveries","Event replay and reprocessing","23+ XRPL event types supported","Developer dashboard with delivery logs","Per-webhook filtering by event type and account"]}7:Tcff,{"@context":"https://schema.org","@type":"FAQPage","@id":"https://www.xrnotify.io/#faqpage","name":"XRNotify FAQ — Common Questions About XRPL Webhooks","mainEntity":[{"@type":"Question","name":"What is XRNotify?","acceptedAnswer":{"@type":"Answer","text":"XRNotify is a real-time webhook notification platform for the XRP Ledger. It monitors XRPL transactions as they confirm on-chain, normalizes them into clean JSON schemas, and delivers them to your endpoints via HMAC-signed HTTPS POST requests. XRNotify eliminates the need to run your own XRPL node or build polling infrastructure."}},{"@type":"Question","name":"What XRPL events does XRNotify support?","acceptedAnswer":{"@type":"Answer","text":"XRNotify supports 23+ event types across all major XRPL transaction categories: payments (XRP and issued tokens), NFT operations (minting, burning, offers, transfers), DEX trades (OfferCreate, OfferCancel, AMM operations), trustline changes (TrustSet), escrow events (create, finish, cancel), check operations, and account-level changes like settings modifications and deletions."}},{"@type":"Question","name":"How does webhook delivery work?","acceptedAnswer":{"@type":"Answer","text":"When an XRPL transaction matches your configured filters, XRNotify normalizes the event, signs the payload with your webhook secret using HMAC-SHA256, and delivers it as an HTTPS POST to your endpoint. If delivery fails, XRNotify retries with exponential backoff (up to 10 attempts over 12 hours). Events that exhaust all retries are moved to a dead-letter queue for manual inspection and replay."}},{"@type":"Question","name":"Is XRNotify free?","acceptedAnswer":{"@type":"Answer","text":"XRNotify offers a free tier with 1,000 events per month and 2 webhook endpoints — enough for testing and hobby projects. Paid plans start at $29/month (Starter: 50,000 events, 10 webhooks, WebSocket streaming) and $99/month (Pro: 500,000 events, 50 webhooks, priority delivery). Enterprise plans with custom SLAs are available on request."}},{"@type":"Question","name":"How do I verify webhook signatures?","acceptedAnswer":{"@type":"Answer","text":"Every XRNotify webhook includes an X-XRNotify-Signature header containing an HMAC-SHA256 hash of the request body, computed using your webhook signing secret. To verify, compute the HMAC-SHA256 of the raw request body with your secret and compare it to the header value using a constant-time comparison function to prevent timing attacks."}},{"@type":"Question","name":"Who built XRNotify?","acceptedAnswer":{"@type":"Answer","text":"XRNotify was built by Ali Morgan, founder of Jonomor, a systems architecture studio focused on AI Visibility and real-time infrastructure intelligence. XRNotify is the XRPL instrumentation layer of the Jonomor ecosystem, which also includes Guard-Clause, MyPropOps, The Neutral Bridge, Evenfield, and H.U.N.I.E."}},{"@type":"Question","name":"Is XRNotify part of a larger ecosystem?","acceptedAnswer":{"@type":"Answer","text":"Yes. XRNotify is part of the Jonomor ecosystem, a suite of interconnected software products built by Ali Morgan. Within the ecosystem, XRNotify serves as the real-time observation layer — detecting XRPL events at the point of origin before they flow through interpretation and operational layers in other Jonomor properties."}}]}0:["pQjrRFT3j-NbWRfetFzsE",[[["",{"children":["docs",{"children":["sdks",{"children":["go",{"children":["__PAGE__",{}]}]}]}]},"$undefined","$undefined",true],["",{"children":["docs",{"children":["sdks",{"children":["go",{"children":["__PAGE__",{},[["$L1",["$","div",null,{"className":"min-h-screen bg-[#0a0a0f] text-white antialiased","children":[["$","nav",null,{"className":"border-b border-zinc-800/50","children":["$","div",null,{"className":"max-w-4xl mx-auto px-6 py-4 flex items-center justify-between","children":[["$","div",null,{"className":"flex items-center gap-2 text-sm","children":[["$","$L2",null,{"href":"/docs","className":"text-zinc-500 hover:text-zinc-300 no-underline","children":"Docs"}],["$","span",null,{"className":"text-zinc-600","children":"/"}],["$","$L2",null,{"href":"/docs#sdks","className":"text-zinc-500 hover:text-zinc-300 no-underline","children":"SDKs"}],["$","span",null,{"className":"text-zinc-600","children":"/"}],["$","span",null,{"className":"text-zinc-300","children":"Go"}]]}],["$","$L2",null,{"href":"/dashboard","className":"text-zinc-400 hover:text-white transition-colors text-sm no-underline","children":"Dashboard →"}]]}]}],["$","main",null,{"className":"max-w-4xl mx-auto px-6 py-12","children":[["$","div",null,{"className":"mb-10","children":[["$","span",null,{"className":"inline-block text-xs font-medium text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 rounded-full px-3 py-1 mb-4","children":"SDKs & Libraries"}],["$","h1",null,{"className":"text-4xl font-bold text-white mb-4","children":"Go SDK"}],["$","p",null,{"className":"text-zinc-400 text-lg leading-relaxed","children":["The official XRNotify Go SDK provides an idiomatic, context-aware client for managing webhooks, querying deliveries, and verifying signatures. Requires Go 1.21 or later. All methods accept a ",["$","code",null,{"className":"font-mono text-emerald-400 bg-emerald-500/10 px-1.5 py-0.5 rounded text-base","children":"context.Context"}]," for cancellation and deadline propagation."]}]]}],["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"text-2xl font-semibold text-white mb-4","children":"Installation"}],["$","div",null,{"className":"bg-zinc-900 border border-zinc-800 rounded-lg p-4 overflow-x-auto","children":["$","pre",null,{"className":"text-sm text-zinc-300 font-mono whitespace-pre","children":"go get github.com/xrnotify/xrnotify-go"}]}]]}],["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"text-2xl font-semibold text-white mb-3","children":"Client setup"}],["$","p",null,{"className":"text-zinc-400 mb-4 leading-relaxed","children":"Create a client with your API key. The client is safe for concurrent use across goroutines."}],["$","div",null,{"className":"bg-zinc-900 border border-zinc-800 rounded-lg p-4 overflow-x-auto mb-4","children":["$","pre",null,{"className":"text-sm text-zinc-300 font-mono whitespace-pre","children":"package main\n\nimport (\n    \"context\"\n    \"fmt\"\n    \"log\"\n    \"os\"\n\n    \"github.com/xrnotify/xrnotify-go\"\n)\n\nfunc main() {\n    client := xrnotify.NewClient(os.Getenv(\"XRNOTIFY_API_KEY\"))\n\n    // Optional: use test environment\n    // client := xrnotify.NewClient(\n    //     os.Getenv(\"XRNOTIFY_TEST_KEY\"),\n    //     xrnotify.WithEnvironment(xrnotify.EnvironmentTest),\n    // )\n\n    ctx := context.Background()\n    _ = client\n    _ = ctx\n}"}]}],["$","div",null,{"className":"bg-emerald-500/10 border border-emerald-500/20 rounded-lg p-3","children":["$","p",null,{"className":"text-emerald-300 text-sm","children":[["$","span",null,{"className":"font-semibold","children":"Thread safety:"}]," A single ",["$","code",null,{"className":"font-mono text-emerald-200 bg-emerald-500/10 px-1 rounded","children":"*xrnotify.Client"}]," can be shared across goroutines. Create one at startup and reuse it throughout the lifetime of your application."]}]}]]}],["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"text-2xl font-semibold text-white mb-3","children":"Creating a webhook"}],["$","p",null,{"className":"text-zinc-400 mb-4 leading-relaxed","children":["Register a webhook endpoint. The returned struct includes ",["$","code",null,{"className":"font-mono text-zinc-300 bg-zinc-800 px-1 rounded","children":"Secret"}]," — this field is only populated on the creation response."]}],["$","div",null,{"className":"bg-zinc-900 border border-zinc-800 rounded-lg p-4 overflow-x-auto mb-4","children":["$","pre",null,{"className":"text-sm text-zinc-300 font-mono whitespace-pre","children":"webhook, err := client.Webhooks.Create(ctx, &xrnotify.CreateWebhookParams{\n    URL:            \"https://yourapp.com/webhooks/xrpl\",\n    EventTypes:     []string{\"payment.xrp\", \"nft.minted\"},\n    AccountFilters: []string{\"rPT1Sjq2YGrBMTttX4GZHjKu9dyfzbpAYe\"},\n    Description:    \"Payment processor\",\n})\nif err != nil {\n    log.Fatalf(\"create webhook: %v\", err)\n}\n\nfmt.Println(\"ID:\", webhook.ID)\nfmt.Println(\"Secret:\", webhook.Secret) // Store immediately — only available once"}]}],["$","div",null,{"className":"bg-amber-500/10 border border-amber-500/20 rounded-lg p-3","children":["$","p",null,{"className":"text-amber-300 text-sm","children":[["$","span",null,{"className":"font-semibold","children":"Important:"}]," ",["$","code",null,{"className":"font-mono text-amber-200 bg-amber-500/10 px-1 rounded","children":"webhook.Secret"}]," is only set in the creation response. Subsequent fetches of the same webhook will return an empty string for this field."]}]}]]}],["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"text-2xl font-semibold text-white mb-3","children":"Listing and managing webhooks"}],["$","p",null,{"className":"text-zinc-400 mb-4 leading-relaxed","children":["List, update, and delete webhooks. The list method returns a paginated result; use ",["$","code",null,{"className":"font-mono text-zinc-300 bg-zinc-800 px-1 rounded","children":"result.HasMore"}]," and ",["$","code",null,{"className":"font-mono text-zinc-300 bg-zinc-800 px-1 rounded","children":"StartingAfter"}]," to page through results."]}],["$","div",null,{"className":"bg-zinc-900 border border-zinc-800 rounded-lg p-4 overflow-x-auto","children":["$","pre",null,{"className":"text-sm text-zinc-300 font-mono whitespace-pre","children":"// List webhooks\nresult, err := client.Webhooks.List(ctx, &xrnotify.ListWebhooksParams{\n    Limit: 10,\n})\nif err != nil {\n    log.Fatal(err)\n}\nfor _, wh := range result.Data {\n    fmt.Println(wh.ID, wh.URL, wh.IsActive)\n}\n\n// Paginate\nif result.HasMore {\n    lastID := result.Data[len(result.Data)-1].ID\n    nextPage, _ := client.Webhooks.List(ctx, &xrnotify.ListWebhooksParams{\n        Limit:         10,\n        StartingAfter: lastID,\n    })\n    _ = nextPage\n}\n\n// Update a webhook\nactive := false\n_, err = client.Webhooks.Update(ctx, \"wh_abc123\", &xrnotify.UpdateWebhookParams{\n    IsActive: &active,\n})\n\n// Delete a webhook\nerr = client.Webhooks.Delete(ctx, \"wh_abc123\")"}]}]]}],["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"text-2xl font-semibold text-white mb-3","children":"Listing deliveries"}],["$","div",null,{"className":"bg-zinc-900 border border-zinc-800 rounded-lg p-4 overflow-x-auto","children":["$","pre",null,{"className":"text-sm text-zinc-300 font-mono whitespace-pre","children":"import \"time\"\n\nsince := time.Date(2024, 1, 1, 0, 0, 0, 0, time.UTC)\ndeliveries, err := client.Deliveries.List(ctx, &xrnotify.ListDeliveriesParams{\n    WebhookID: \"wh_abc123\",\n    Status:    \"failed\",\n    Since:     &since,\n})\nif err != nil {\n    log.Fatal(err)\n}\nfor _, d := range deliveries.Data {\n    fmt.Println(d.ID, d.EventType, d.StatusCode, d.LastError)\n}"}]}]]}],["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"text-2xl font-semibold text-white mb-3","children":"Verifying signatures"}],["$","p",null,{"className":"text-zinc-400 mb-4 leading-relaxed","children":["Use the ",["$","code",null,{"className":"font-mono text-zinc-300 bg-zinc-800 px-1 rounded","children":"verify"}]," sub-package to validate incoming webhook requests. The function uses ",["$","code",null,{"className":"font-mono text-zinc-300 bg-zinc-800 px-1 rounded","children":"hmac.Equal"}]," for constant-time comparison."]}],["$","div",null,{"className":"bg-zinc-900 border border-zinc-800 rounded-lg p-4 overflow-x-auto mb-4","children":["$","pre",null,{"className":"text-sm text-zinc-300 font-mono whitespace-pre","children":"$3"}]}],["$","div",null,{"className":"bg-amber-500/10 border border-amber-500/20 rounded-lg p-3","children":["$","p",null,{"className":"text-amber-300 text-sm","children":[["$","span",null,{"className":"font-semibold","children":"Raw body required:"}]," Read the body with ",["$","code",null,{"className":"font-mono text-amber-200 bg-amber-500/10 px-1 rounded","children":"io.ReadAll"}]," before calling ",["$","code",null,{"className":"font-mono text-amber-200 bg-amber-500/10 px-1 rounded","children":"verify.Signature"}],". Do not use a JSON decoder directly on ",["$","code",null,{"className":"font-mono text-amber-200 bg-amber-500/10 px-1 rounded","children":"r.Body"}]," before verification."]}]}]]}],["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"text-2xl font-semibold text-white mb-3","children":"Struct types"}],["$","p",null,{"className":"text-zinc-400 mb-4 leading-relaxed","children":["The SDK provides typed structs for all event envelopes and payloads. The ",["$","code",null,{"className":"font-mono text-zinc-300 bg-zinc-800 px-1 rounded","children":"Payload"}]," field is a ",["$","code",null,{"className":"font-mono text-zinc-300 bg-zinc-800 px-1 rounded","children":"json.RawMessage"}]," so you can unmarshal it into the appropriate typed struct based on ",["$","code",null,{"className":"font-mono text-zinc-300 bg-zinc-800 px-1 rounded","children":"EventType"}],"."]}],["$","div",null,{"className":"bg-zinc-900 border border-zinc-800 rounded-lg p-4 overflow-x-auto","children":["$","pre",null,{"className":"text-sm text-zinc-300 font-mono whitespace-pre","children":"// Event envelope — same structure for all event types\ntype Event struct {\n    EventID     string          `json:\"event_id\"`\n    EventType   string          `json:\"event_type\"`\n    LedgerIndex int64           `json:\"ledger_index\"`\n    Timestamp   time.Time       `json:\"timestamp\"`\n    Network     string          `json:\"network\"`\n    WebhookID   string          `json:\"webhook_id\"`\n    Payload     json.RawMessage `json:\"payload\"`\n}\n\n// Typed payload structs\ntype PaymentXrpPayload struct {\n    Sender         string  `json:\"sender\"`\n    Receiver       string  `json:\"receiver\"`\n    Amount         string  `json:\"amount\"`\n    AmountXRP      string  `json:\"amount_xrp\"`\n    Fee            string  `json:\"fee\"`\n    DeliveredAmount string `json:\"delivered_amount\"`\n    DestinationTag *int64  `json:\"destination_tag\"`\n    SourceTag      *int64  `json:\"source_tag\"`\n    TxHash         string  `json:\"tx_hash\"`\n    LedgerIndex    int64   `json:\"ledger_index\"`\n    Sequence       int64   `json:\"sequence\"`\n}"}]}]]}],["$","section",null,{"children":[["$","h2",null,{"className":"text-2xl font-semibold text-white mb-4","children":"Related"}],["$","div",null,{"classNa