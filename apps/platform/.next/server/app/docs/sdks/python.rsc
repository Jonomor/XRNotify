5:T4b8,{"@context":"https://schema.org","@type":"SoftwareApplication","@id":"https://www.xrnotify.io/#app","name":"XRNotify","description":"Real-time webhook notification platform for the XRP Ledger.","url":"https://www.xrnotify.io","applicationCategory":"DeveloperApplication","operatingSystem":"Web","offers":[{"@type":"Offer","name":"Free","price":"0","priceCurrency":"USD","description":"1,000 events/month, 2 webhooks"},{"@type":"Offer","name":"Starter","price":"29.00","priceCurrency":"USD","description":"50,000 events/month, 10 webhooks, WebSocket access"},{"@type":"Offer","name":"Pro","price":"99.00","priceCurrency":"USD","description":"500,000 events/month, 50 webhooks, priority delivery"}],"creator":{"@id":"https://www.jonomor.com/ali-morgan#person"},"publisher":{"@id":"https://www.jonomor.com/#organization"},"isPartOf":{"@id":"https://www.jonomor.com/#organization"},"featureList":["Real-time XRPL event ingestion","HMAC-SHA256 signed webhook delivery","Automatic retries with exponential backoff","Dead-letter queue for failed deliveries","Event replay and reprocessing","23+ XRPL event types supported","Developer dashboard with delivery logs","Per-webhook filtering by event type and account"]}6:Tcff,{"@context":"https://schema.org","@type":"FAQPage","@id":"https://www.xrnotify.io/#faqpage","name":"XRNotify FAQ — Common Questions About XRPL Webhooks","mainEntity":[{"@type":"Question","name":"What is XRNotify?","acceptedAnswer":{"@type":"Answer","text":"XRNotify is a real-time webhook notification platform for the XRP Ledger. It monitors XRPL transactions as they confirm on-chain, normalizes them into clean JSON schemas, and delivers them to your endpoints via HMAC-signed HTTPS POST requests. XRNotify eliminates the need to run your own XRPL node or build polling infrastructure."}},{"@type":"Question","name":"What XRPL events does XRNotify support?","acceptedAnswer":{"@type":"Answer","text":"XRNotify supports 23+ event types across all major XRPL transaction categories: payments (XRP and issued tokens), NFT operations (minting, burning, offers, transfers), DEX trades (OfferCreate, OfferCancel, AMM operations), trustline changes (TrustSet), escrow events (create, finish, cancel), check operations, and account-level changes like settings modifications and deletions."}},{"@type":"Question","name":"How does webhook delivery work?","acceptedAnswer":{"@type":"Answer","text":"When an XRPL transaction matches your configured filters, XRNotify normalizes the event, signs the payload with your webhook secret using HMAC-SHA256, and delivers it as an HTTPS POST to your endpoint. If delivery fails, XRNotify retries with exponential backoff (up to 10 attempts over 12 hours). Events that exhaust all retries are moved to a dead-letter queue for manual inspection and replay."}},{"@type":"Question","name":"Is XRNotify free?","acceptedAnswer":{"@type":"Answer","text":"XRNotify offers a free tier with 1,000 events per month and 2 webhook endpoints — enough for testing and hobby projects. Paid plans start at $29/month (Starter: 50,000 events, 10 webhooks, WebSocket streaming) and $99/month (Pro: 500,000 events, 50 webhooks, priority delivery). Enterprise plans with custom SLAs are available on request."}},{"@type":"Question","name":"How do I verify webhook signatures?","acceptedAnswer":{"@type":"Answer","text":"Every XRNotify webhook includes an X-XRNotify-Signature header containing an HMAC-SHA256 hash of the request body, computed using your webhook signing secret. To verify, compute the HMAC-SHA256 of the raw request body with your secret and compare it to the header value using a constant-time comparison function to prevent timing attacks."}},{"@type":"Question","name":"Who built XRNotify?","acceptedAnswer":{"@type":"Answer","text":"XRNotify was built by Ali Morgan, founder of Jonomor, a systems architecture studio focused on AI Visibility and real-time infrastructure intelligence. XRNotify is the XRPL instrumentation layer of the Jonomor ecosystem, which also includes Guard-Clause, MyPropOps, The Neutral Bridge, Evenfield, and H.U.N.I.E."}},{"@type":"Question","name":"Is XRNotify part of a larger ecosystem?","acceptedAnswer":{"@type":"Answer","text":"Yes. XRNotify is part of the Jonomor ecosystem, a suite of interconnected software products built by Ali Morgan. Within the ecosystem, XRNotify serves as the real-time observation layer — detecting XRPL events at the point of origin before they flow through interpretation and operational layers in other Jonomor properties."}}]}0:["pQjrRFT3j-NbWRfetFzsE",[[["",{"children":["docs",{"children":["sdks",{"children":["python",{"children":["__PAGE__",{}]}]}]}]},"$undefined","$undefined",true],["",{"children":["docs",{"children":["sdks",{"children":["python",{"children":["__PAGE__",{},[["$L1",["$","div",null,{"className":"min-h-screen bg-[#0a0a0f] text-white antialiased","children":[["$","nav",null,{"className":"border-b border-zinc-800/50","children":["$","div",null,{"className":"max-w-4xl mx-auto px-6 py-4 flex items-center justify-between","children":[["$","div",null,{"className":"flex items-center gap-2 text-sm","children":[["$","$L2",null,{"href":"/docs","className":"text-zinc-500 hover:text-zinc-300 no-underline","children":"Docs"}],["$","span",null,{"className":"text-zinc-600","children":"/"}],["$","$L2",null,{"href":"/docs#sdks","className":"text-zinc-500 hover:text-zinc-300 no-underline","children":"SDKs"}],["$","span",null,{"className":"text-zinc-600","children":"/"}],["$","span",null,{"className":"text-zinc-300","children":"Python"}]]}],["$","$L2",null,{"href":"/dashboard","className":"text-zinc-400 hover:text-white transition-colors text-sm no-underline","children":"Dashboard →"}]]}]}],["$","main",null,{"className":"max-w-4xl mx-auto px-6 py-12","children":[["$","div",null,{"className":"mb-10","children":[["$","span",null,{"className":"inline-block text-xs font-medium text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 rounded-full px-3 py-1 mb-4","children":"SDKs & Libraries"}],["$","h1",null,{"className":"text-4xl font-bold text-white mb-4","children":"Python SDK"}],["$","p",null,{"className":"text-zinc-400 text-lg leading-relaxed","children":"The official XRNotify Python SDK provides a synchronous and async-compatible interface for managing webhooks, querying deliveries, and verifying signatures. Full Pydantic models are included for type-safe event handling."}]]}],["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"text-2xl font-semibold text-white mb-4","children":"Installation"}],["$","div",null,{"className":"bg-zinc-900 border border-zinc-800 rounded-lg p-4 overflow-x-auto mb-4","children":["$","pre",null,{"className":"text-sm text-zinc-300 font-mono whitespace-pre","children":"pip install xrnotify"}]}],["$","div",null,{"className":"grid grid-cols-3 gap-3","children":[["$","div",null,{"className":"bg-zinc-900 border border-zinc-800 rounded-lg p-3 text-center","children":[["$","p",null,{"className":"text-zinc-400 text-xs mb-1","children":"Python"}],["$","p",null,{"className":"text-white font-mono text-sm","children":"3.8+"}]]}],["$","div",null,{"className":"bg-zinc-900 border border-zinc-800 rounded-lg p-3 text-center","children":[["$","p",null,{"className":"text-zinc-400 text-xs mb-1","children":"HTTP"}],["$","p",null,{"className":"text-white font-mono text-sm","children":"httpx"}]]}],["$","div",null,{"className":"bg-zinc-900 border border-zinc-800 rounded-lg p-3 text-center","children":[["$","p",null,{"className":"text-zinc-400 text-xs mb-1","children":"Types"}],["$","p",null,{"className":"text-white font-mono text-sm","children":"pydantic"}]]}]]}]]}],["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"text-2xl font-semibold text-white mb-3","children":"Initialization"}],["$","p",null,{"className":"text-zinc-400 mb-4 leading-relaxed","children":"Import and instantiate the client with your API key from an environment variable."}],["$","div",null,{"className":"bg-zinc-900 border border-zinc-800 rounded-lg p-4 overflow-x-auto mb-4","children":["$","pre",null,{"className":"text-sm text-zinc-300 font-mono whitespace-pre","children":"import os\nfrom xrnotify import XRNotify\n\nclient = XRNotify(api_key=os.environ[\"XRNOTIFY_API_KEY\"])\n\n# Optional: use the test environment\n# client = XRNotify(\n#     api_key=os.environ[\"XRNOTIFY_TEST_KEY\"],\n#     environment=\"test\"\n# )"}]}],["$","div",null,{"className":"bg-emerald-500/10 border border-emerald-500/20 rounded-lg p-3","children":["$","p",null,{"className":"text-emerald-300 text-sm","children":[["$","span",null,{"className":"font-semibold","children":"Test environment:"}]," Pass ",["$","code",null,{"className":"font-mono text-emerald-200 bg-emerald-500/10 px-1 rounded","children":"environment=\"test\""}]," to use test API keys. Synthetic events will be delivered without consuming real XRPL data."]}]}]]}],["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"text-2xl font-semibold text-white mb-3","children":"Creating a webhook"}],["$","p",null,{"className":"text-zinc-400 mb-4 leading-relaxed","children":["Register a webhook endpoint. The ",["$","code",null,{"className":"font-mono text-zinc-300 bg-zinc-800 px-1 rounded","children":"secret"}]," attribute is only present on the creation response."]}],["$","div",null,{"className":"bg-zinc-900 border border-zinc-800 rounded-lg p-4 overflow-x-auto mb-4","children":["$","pre",null,{"className":"text-sm text-zinc-300 font-mono whitespace-pre","children":"webhook = client.webhooks.create(\n    url=\"https://yourapp.com/webhooks/xrpl\",\n    event_types=[\"payment.xrp\", \"nft.minted\"],\n    account_filters=[\"rPT1Sjq2YGrBMTttX4GZHjKu9dyfzbpAYe\"],\n    description=\"Payment processor\"\n)\n\nprint(webhook.id)      # wh_abc123\nprint(webhook.secret)  # Only available on creation — store immediately"}]}],["$","div",null,{"className":"bg-amber-500/10 border border-amber-500/20 rounded-lg p-3","children":["$","p",null,{"className":"text-amber-300 text-sm","children":[["$","span",null,{"className":"font-semibold","children":"Important:"}]," The ",["$","code",null,{"className":"font-mono text-amber-200 bg-amber-500/10 px-1 rounded","children":"secret"}]," field is returned once at creation. It cannot be retrieved again. Store it in your secrets manager immediately."]}]}]]}],["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"text-2xl font-semibold text-white mb-3","children":"Listing and updating webhooks"}],["$","p",null,{"className":"text-zinc-400 mb-4 leading-relaxed","children":"List all webhooks in your account and update existing ones. Only the keyword arguments you pass are changed."}],["$","div",null,{"className":"bg-zinc-900 border border-zinc-800 rounded-lg p-4 overflow-x-auto","children":["$","pre",null,{"className":"text-sm text-zinc-300 font-mono whitespace-pre","children":"# List webhooks\nresult = client.webhooks.list(limit=10)\nfor wh in result.data:\n    print(wh.id, wh.url, wh.is_active)\n\n# Paginate\nif result.has_more:\n    next_page = client.webhooks.list(\n        limit=10,\n        starting_after=result.data[-1].id\n    )\n\n# Pause a webhook\nclient.webhooks.update(\"wh_abc123\", is_active=False)\n\n# Update subscribed event types\nclient.webhooks.update(\"wh_abc123\", event_types=[\"payment.*\", \"nft.*\"])\n\n# Delete a webhook\nclient.webhooks.delete(\"wh_abc123\")"}]}]]}],["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"text-2xl font-semibold text-white mb-3","children":"Listing deliveries"}],["$","p",null,{"className":"text-zinc-400 mb-4 leading-relaxed","children":["Query delivery history filtered by webhook, status, and time range. Pass a timezone-aware ",["$","code",null,{"className":"font-mono text-zinc-300 bg-zinc-800 px-1 rounded","children":"datetime"}]," for the ",["$","code",null,{"className":"font-mono text-zinc-300 bg-zinc-800 px-1 rounded","children":"since"}]," parameter."]}],["$","div",null,{"className":"bg-zinc-900 border border-zinc-800 rounded-lg p-4 overflow-x-auto","children":["$","pre",null,{"className":"text-sm text-zinc-300 font-mono whitespace-pre","children":"from datetime import datetime, timezone\n\nresult = client.deliveries.list(\n    webhook_id=\"wh_abc123\",\n    status=\"failed\",\n    since=datetime(2024, 1, 1, tzinfo=timezone.utc)\n)\n\nfor delivery in result.data:\n    print(\n        delivery.id,\n        delivery.event_type,\n        delivery.status_code,\n        delivery.last_error\n    )"}]}]]}],["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"text-2xl font-semibold text-white mb-3","children":"Verifying signatures"}],["$","p",null,{"className":"text-zinc-400 mb-4 leading-relaxed","children":["Use ",["$","code",null,{"className":"font-mono text-zinc-300 bg-zinc-800 px-1 rounded","children":"verify_signature"}]," from the SDK to validate incoming webhook requests. The function uses ",["$","code",null,{"className":"font-mono text-zinc-300 bg-zinc-800 px-1 rounded","children":"hmac.compare_digest"}]," internally for constant-time comparison."]}],["$","div",null,{"className":"bg-zinc-900 border border-zinc-800 rounded-lg p-4 overflow-x-auto mb-4","children":["$","pre",null,{"className":"text-sm text-zinc-300 font-mono whitespace-pre","children":"import os\nfrom flask import Flask, request\nfrom xrnotify import verify_signature\n\napp = Flask(__name__)\n\n@app.route(\"/webhooks/xrpl\", methods=[\"POST\"])\ndef handle_webhook():\n    # Verify before parsing — use request.data (raw bytes)\n    if not verify_signature(\n        payload=request.data,\n        signature=request.headers.get(\"X-XRNotify-Signature\", \"\"),\n        secret=os.environ[\"WEBHOOK_SECRET\"]\n    ):\n        return \"Unauthorized\", 401\n\n    event = request.get_json(force=True)\n    handle_event(event)\n    return \"OK\", 200\n\n\ndef handle_event(event: dict) -> None:\n    event_type = event.get(\"event_type\")\n    if event_type == \"payment.xrp\":\n        payload = event[\"payload\"]\n        print(f\"XRP payment: {payload['amount_xrp']} XRP\")\n    elif event_type == \"nft.minted\":\n        payload = event[\"payload\"]\n        print(f\"NFT minted: {payload['nft_id']}\")"}]}],["$","div",null,{"className":"bg-amber-500/10 border border-amber-500/20 rounded-lg p-3","children":["$","p",null,{"className":"text-amber-300 text-sm","children":[["$","span",null,{"className":"font-semibold","children":"Raw body required:"}]," Pass ",["$","code",null,{"className":"font-mono text-amber-200 bg-amber-500/10 px-1 rounded","children":"request.data"}]," (bytes), not ",["$","code",null,{"className":"font-mono text-amber-200 bg-amber-500/10 px-1 rounded","children":"request.get_json()"}],". The signature is computed over the raw bytes before any JSON parsing."]}]}]]}],["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"text-2xl font-semibold text-white mb-3","children":"Pydantic models"}],["$","p",null,{"className":"text-zinc-400 mb-4 leading-relaxed","children":"The SDK ships Pydantic v2 models for every event type. Use them for validation, serialization, and IDE autocompletion."}],["$","div",null,{"className":"bg-zinc-900 border border-zinc-800 rounded-lg p-4 overflow-x-auto","children":["$","pre",null,{"className":"text-sm text-zinc-300 font-mono whitespace-pre","children":"from xrnotify.models import (\n    WebhookEvent,\n    PaymentXrpPayload,\n    PaymentIssuedPayload,\n    NftMintedPayload,\n    DexOfferFilledPayload,\n)\n\n\ndef handle_event(data: dict) -> None:\n    event = WebhookEvent(**data)\n\n    if event.event_type == \"payment.xrp\":\n        payload = PaymentXrpPayload(**event.payload)\n        print(f\"Received {payload.amount_xrp} XRP\")\n        print(f\"From: {payload.sender} → {payload.receiver}\")\n\n    elif event.event_type == \"nft.minted\":\n        payload = NftMintedPayload(**event.payload)\n        print(f\"NFT {payload.nft_id} minted by {payload.issuer}\")\n        if payload.uri_decoded:\n            print(f\"Metadata: {payload.uri_decoded}\")"}]}]]}],["$","section",null,{"children":[["$","h2",null,{"className":"text-2xl font-semibold text-white mb-4","children":"Related"}],["$","div",null,{"className":"grid grid-cols-1 sm:grid-cols-3 gap-4","children":[["$","$L2",null,{"href":"/docs/sdks/nodejs","className":"block bg-zinc-900 border border-zinc-800 hover:border-zinc-600 rounded-lg p-4 no-underline transition-colors","children":[["$","p",null,{"className":"text-white font-medium mb-1","children":"Node.js SDK"}],["$","p",null,{"className":"text-zinc-500 text-sm","children":"npm install @xrnotify/sdk"}]]}],["$","$L2",null,{"href":"/docs/sdks/go","className":"block bg-zinc-900 border border-zinc-800 hover:border-zinc-600 rounded-lg p-4 no-underline transition-colors","children":[["$","p",null,{"className":"text-white font-medium mb-1","children":"Go SDK"}],["$","p",null,{"className":"text-zinc-500 text-sm","children":"go get github.com/xrnotify/xrnotify-go"}]]}],["$","$L2",null,{"href":"/docs/sdks/signature-helpers","className":"block bg-zinc-900 border border-zinc-800 hover:border-zinc-600 rounded-lg p-4 no-underline transition-colors","children":[["$","p",null,{"className":"text-white font-medium mb-1","children":"Signature Helpers"}],["$","p",null,{"className":"text-zinc-500 text-sm","children":"Copy-paste verification for any language"}]]}]]}]]}]]}]]}],null],null],null]},[null,["$","$L3",null,{"parallelRouterKey":"children","segmentPath":["children","docs","children","sdks","children","python","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L4",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]],null]},[null,["$","$L3",null,{"parallelRouterKey":"children","segmentPath":["children","docs","children","sdks","children