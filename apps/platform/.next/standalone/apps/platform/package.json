{
  "name": "@xrnotify/platform",
  "version": "1.0.0",
  "private": true,
  "description": "XRNotify Platform - Next.js API & Dashboard",
  "author": "XRNotify <engineering@xrnotify.io>",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "prebuild": "rm -rf .next/cache || true",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "node --import tsx src/lib/db/migrate.ts",
    "db:migrate:create": "node --import tsx src/lib/db/migrate.ts create",
    "clean": "rm -rf .next .turbo node_modules"
  },
  "dependencies": {
    "@xrnotify/shared": "workspace:*",
    "next": "^14.2.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "pg": "^8.12.0",
    "ioredis": "^5.4.1",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "zod": "^3.23.8",
    "jose": "^5.9.2",
    "bcryptjs": "^2.4.3",
    "prom-client": "^15.1.3",
    "stripe": "^16.10.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.2",
    "lucide-react": "^0.441.0",
    "@tanstack/react-query": "^5.56.2",
    "zustand": "^4.5.5",
    "recharts": "^2.12.7",
    "date-fns": "^3.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.8",
    "@types/react-dom": "^18.3.0",
    "@types/pg": "^8.11.10",
    "@types/bcryptjs": "^2.4.6",
    "typescript": "^5.6.2",
    "tailwindcss": "^3.4.11",
    "postcss": "^8.4.47",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.10",
    "vitest": "^2.1.1",
    "@vitejs/plugin-react": "^4.3.1",
    "tsx": "^4.19.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
